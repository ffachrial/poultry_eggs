// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(USER)
  accounts      Account[]
  sessions      Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Cage {
  id           String     @id @default(cuid())
  name         String     @unique
  chickenCount Int        @default(2)
  eggLogs      EggLog[]
  dailyLogs    DailyLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EggLog {
  id        String   @id @default(cuid())
  cageId    String
  date      DateTime @default(now())
  qualityS  Int      @default(0)
  qualityR  Int      @default(0)
  qualityP  Int      @default(0)
  totalGood Int // S + R
  notes     String?

  cage Cage @relation(fields: [cageId], references: [id], onDelete: Cascade)

  @@index([date])
}

enum TimeSlot {
  PAGI
  SIANG
  SORE
  MALAM
}

model DailyLog {
  id           String   @id @default(cuid())
  cageId       String
  date         DateTime @default(now())
  timeSlot     TimeSlot
  mortality    Int      @default(0)
  feedQuantity Float    @default(0) // in Kg

  cage Cage @relation(fields: [cageId], references: [id], onDelete: Cascade)

  @@unique([cageId, date, timeSlot])
  @@index([date])
}

model Sale {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  buyerName   String
  weightKg    Float
  unitPrice   Float
  totalAmount Float
  notes       String?

  @@index([date])
}

model Expense {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  category    String
  amount      Float
  description String?

  @@index([date])
}